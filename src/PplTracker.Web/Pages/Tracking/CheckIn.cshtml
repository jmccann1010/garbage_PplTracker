@page
@model PplTracker.Web.Pages.Tracking.CheckInModel
@{
    ViewData["Title"] = "Check In";
}

<div style="max-width: 500px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <fluent-button appearance="stealth" onclick="window.location='/Tracking'">← Back</fluent-button>
        <h2 style="margin: 0; color: #323130;">Check In</h2>
    </div>

    <fluent-card style="padding: 24px;">
        <form method="post">
            @Html.AntiForgeryToken()

            <div style="display: grid; gap: 16px;">
                <div>
                    <label style="display: block; margin-bottom: 4px; font-size: 14px; color: #323130;">Person *</label>
                    <select asp-for="Input.PersonId" asp-items="Model.PeopleOptions" required
                            style="width: 100%; padding: 8px; border: 1px solid #8a8886; border-radius: 2px; font-size: 14px;">
                        <option value="">Select a person...</option>
                    </select>
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-size: 14px; color: #323130;">Location *</label>
                    <select asp-for="Input.LocationId" asp-items="Model.LocationsOptions" required
                            style="width: 100%; padding: 8px; border: 1px solid #8a8886; border-radius: 2px; font-size: 14px;">
                        <option value="">Select a location...</option>
                    </select>
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-size: 14px; color: #323130;">Notes</label>
                    <fluent-text-area asp-for="Input.Notes" style="width: 100%;" rows="3"></fluent-text-area>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <fluent-message-bar intent="error">@Model.ErrorMessage</fluent-message-bar>
                }

                <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px;">
                    <fluent-button onclick="window.location='/Tracking'">Cancel</fluent-button>
                    <fluent-button type="submit" appearance="accent">Check In</fluent-button>
                </div>
            </div>
        </form>
    </fluent-card>
</div>
